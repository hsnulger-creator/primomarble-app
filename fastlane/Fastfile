default_platform(:ios)

platform :ios do
  desc "Build for App Store"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: "3CL3588VSB",
      issuer_id: "cf8f6456-896e-47ed-a844-e20e07e7126f",
      key_filepath: ENV["KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    cert(
      api_key: api_key,
      output_path: "#{ENV.fetch('RUNNER_TEMP', '/tmp')}/certs",
      filename: "distribution"
    )

    # Export the certificate + key as p12 so we can save it as a secret for future runs
    p12_path = "#{ENV.fetch('RUNNER_TEMP', '/tmp')}/certs/distribution.p12"
    p12_password = "primomarble123"
    sh("security export -k ~/Library/Keychains/login.keychain-db -t identities -f pkcs12 -P '#{p12_password}' -o '#{p12_path}' 2>/dev/null || security export -k /Library/Keychains/System.keychain -t identities -f pkcs12 -P '#{p12_password}' -o '#{p12_path}'")
    p12_b64 = sh("base64 -i '#{p12_path}'", log: false).strip
    puts "===== SAVE THIS AS GITHUB SECRET 'DISTRIBUTION_CERT_P12' ====="
    puts p12_b64
    puts "===== P12 PASSWORD IS: #{p12_password} (save as 'DISTRIBUTION_CERT_PASSWORD') ====="

    sigh(
      api_key: api_key,
      app_identifier: "com.primomarble.daycheckapp",
      output_path: "#{ENV.fetch('RUNNER_TEMP', '/tmp')}/profiles",
      force: true
    )

    build_app(
      workspace: "ios/PrimoMarble.xcworkspace",
      scheme: "PrimoMarble",
      configuration: "Release",
      output_directory: "ios/output",
      output_name: "PrimoMarble.ipa",
      export_method: "app-store",
      xcargs: "DEVELOPMENT_TEAM=K6864D294S CODE_SIGN_STYLE=Automatic",
      export_options: {
        teamID: "K6864D294S",
        uploadBitcode: false,
        compileBitcode: false
      }
    )
  end
end
